class_name TriggerListenerDefinition
extends Resource
## A listener that registers on the EventBus via TriggerComponent.
## When the specified event fires and all conditions pass, executes effects.
## Used by statuses, items, talents, and run buffs.

@export var event: String = ""                        ## "on_hit_dealt", "on_kill", "on_crit", etc.
@export var conditions: Array[Resource] = []          ## Typed trigger condition sub-resources
@export var effects: Array[Resource] = []             ## Typed effect sub-resources (same pool as ability effects)
@export var target_self: bool = false                 ## When true, effects target the entity bearing the trigger (not the event target)
@export var target_event_source: bool = false         ## When true, effects target the event source (e.g. stun the entity that attempted displacement)
@export var target_summon_id: String = ""             ## When non-empty, effects target the bearer's active summon with this id (skipped if summon missing/dead). First consumer: Cleric Spirit Link (heal the Spirit Guardian whenever the Cleric heals an ally).
@export var target_event_applier: bool = false        ## When true, effects target the original applier of the event's status (read from on_cleanse payload). Falls back to nearest enemy when the applier is dead/freed. First consumer: Cleric Purifying Fire (Holy damage to whoever cast the cleansed debuff).
@export var target_nearest_debuffed_ally_to_source: bool = false  ## When true, effects target the nearest allied hero (excludes summons) within target_radius of the event source's position that has at least one active negative status. Skipped when no eligible target exists. First consumer: Cleric Consecrated Spirit (cleanse a debuff from the nearest hero near the Spirit Guardian).
@export var target_radius: float = 0.0                ## Search radius for proximity-based target resolution modes (target_nearest_debuffed_ally_to_source). Pixels.
@export var target_excludes_status_id: String = ""    ## When non-empty, the proximity resolver skips candidates carrying this status — per-target ICD pattern. First consumer: Cleric Consecrated Spirit's per-ally `consecrated_spirit_icd` 4s cooldown marker.
@export var target_random_near_event_target: bool = false  ## When true, effects target a single random same-faction-as-event-target entity within target_radius of the event target's position. Rolls combat_manager.rng. Skipped when no eligible candidate exists. First consumer: Wizard Sympathetic Flames (random fewer-burn neighbor of the hit enemy).
@export var target_fewer_stacks_status_id: String = ""  ## When non-empty, `target_random_near_event_target` candidates must have fewer stacks of this status than the event target. Stack comparison filter — paired with the random resolver, not independently evaluated. First consumer: Wizard Sympathetic Flames (candidates must have fewer Burn stacks than the hit enemy).
@export var proc_chance: float = 1.0                  ## Rolled after conditions pass, before trigger_fired emit and effect dispatch. 1.0 = always proc (default); < 1.0 = combat_manager.rng.randf() gate. First consumer: Wizard Sympathetic Flames (20% per-hit proc).
@export var target_priority_tiers: Array[String] = []  ## When non-empty, effects target the BEARER's next living enemy matching these priority tiers (same classification as "priority_tiered_enemy" targeting — TargetingRule.entity_matches_priority_tier). Walks tiers in order; first tier with any living match wins, pick the nearest candidate from the bearer's position. NO nearest-fallback (distinct from "priority_tiered_enemy" targeting, which falls back to nearest_enemy when no tier matches) — listener is skipped entirely when no priority target is on the field. Filters is_alive because the spatial grid rebuilds at frame start and may still contain a just-killed victim. First consumer: Ranger Waste Not (prime the next priority target with 5 Mark stacks on-kill; noop when no next priority target exists).
@export var allow_proc_hits: bool = false  ## Default false — hit-shaped events (on_hit_dealt / on_hit_received / on_crit / on_block / on_dodge / on_absorb) skip listener evaluation when hit_data.ability is null. Mirrors the existing convention in entity.take_damage (`notify_hit_dealt` only fires for ability-driven hits "to prevent recursion from proc damage"). Without this guard, an on_hit_dealt listener that DEALS damage as its effect would re-fire on its own derived hit and recurse infinitely. Set true on the rare listener that legitimately needs to react to DOT ticks, thorns reflects, or other null-ability hits.
